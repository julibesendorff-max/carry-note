{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "diagnostico/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "radar/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "analisis/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "aprender/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/notify.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/diagnose.js",
      "use": "@vercel/node"
    },
    {
      "src": "sponsors/index.html",
      "use": "@vercel/static"
    },
    {
      "src": "og-image.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/notify",
      "dest": "/api/notify.js"
    },
    {
      "src": "/api/diagnose",
      "dest": "/api/diagnose.js"
    },
    {
      "src": "/diagnostico",
      "dest": "/diagnostico/index.html"
    },
    {
      "src": "/radar",
      "dest": "/radar/index.html"
    },
    {
      "src": "/analisis",
      "dest": "/analisis/index.html"
    },
    {
      "src": "/aprender",
      "dest": "/aprender/index.html"
    },
    {
      "src": "/sponsors",
      "dest": "/sponsors/index.html"
    },
    {
      "src": "/og-image.png",
      "dest": "/og-image.png"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/sitemap.xml"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
